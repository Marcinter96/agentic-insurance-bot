GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Bidi (live voice) settings — used by bidi_local.py
# Vertex AI native-audio Live model (default). For AI Studio use:
#   gemini-2.5-flash-native-audio-preview-12-2025
BIDI_AGENT_MODEL=gemini-live-2.5-flash-native-audio
# Logging verbosity for bidi_local.py: DEBUG | INFO | WARNING
LOG_LEVEL=INFO
