# ── Core (Vertex AI) ────────────────────────────────────────────────────────
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# ── Models ──────────────────────────────────────────────────────────────────
LLM_MODEL=gemini-2.5-flash          # specialists (tool-calling)
BRAIN_MODEL=gemini-2.5-flash-lite   # fast one-shot intake brains (thinking off)

# ── Storage buckets (keep all in the same region as the service) ─────────────
GCS_BUCKET=adk-insurance-demo-data-mi   # customer data
SOS_BUCKET=adk-insurance-sos-mi         # emergency interaction records
OFFER_BUCKET=adk-insurance-offer-mi     # product catalog + sales leads
CLAIMS_BUCKET=adk-insurance-claims-mi   # filed claims + escalations

# ── Bidi (live voice) — used by bidi_local.py only ───────────────────────────
BIDI_AGENT_MODEL=gemini-live-2.5-flash-native-audio
LOG_LEVEL=INFO
